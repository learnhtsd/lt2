local Settings = {}

function Settings:Load(Tab, MainFrame, ScreenGui)
    local Hub = _G.Hub -- Get the API from the global table
    
    -- SECTION 1
    Hub:AddSection(Tab, "Keybinds")
    
    Hub:AddButton(Tab, "Toggle Key: Right Ctrl", function()
        print("Rebind clicked")
    end)

    -- SECTION 2
    Hub:AddSection(Tab, "Menu Layout")

    Hub:AddButton(Tab, "Scale Up", function()
        MainFrame.Size += UDim2.fromOffset(20,15)
    end)

    Hub:AddButton(Tab, "Scale Down", function()
        MainFrame.Size -= UDim2.fromOffset(20,15)
    end)

    -- SECTION 3
    Hub:AddSection(Tab, "Danger Zone")

    Hub:AddButton(Tab, "Unload", function()
        ScreenGui:Destroy()
    end)
end

return Settings
