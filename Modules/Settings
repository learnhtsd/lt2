local Settings = {}

function Settings:Load(Tab, MainFrame, ScreenGui)
    local Hub = _G.Hub
    
    -- Category 1
    Hub:AddSection(Tab, "Configuration")
    Hub:AddButton(Tab, "Toggle Key: Right Ctrl", function() print("Bind UI clicked") end)

    -- Category 2
    Hub:AddSection(Tab, "UI Customization")
    Hub:AddButton(Tab, "Increase Scale", function() MainFrame.Size += UDim2.fromOffset(20,15) end)
    Hub:AddButton(Tab, "Decrease Scale", function() MainFrame.Size -= UDim2.fromOffset(20,15) end)

    -- Category 3
    Hub:AddSection(Tab, "Danger Zone")
    Hub:AddButton(Tab, "Unload Script", function() ScreenGui:Destroy() end)
end

return Settings
