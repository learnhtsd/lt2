local Settings = {}

function Settings:Load(Tab, MainFrame, ScreenGui)
    local Hub = _G.Hub -- Access the Hub API from the main script
    
    -- SECTION: INPUT
    Hub:AddSection(Tab, "Controls")
    
    Hub:AddButton(Tab, "Toggle Key: Right Ctrl", function()
        print("Rebinding UI is coming soon...")
    end)

    -- SECTION: MENU
    Hub:AddSection(Tab, "Interface Settings")

    Hub:AddButton(Tab, "Scale Up", function()
        MainFrame.Size += UDim2.fromOffset(20,15)
    end)

    Hub:AddButton(Tab, "Scale Down", function()
        MainFrame.Size -= UDim2.fromOffset(20,15)
    end)

    -- SECTION: SYSTEM
    Hub:AddSection(Tab, "Utility")

    Hub:AddButton(Tab, "Unload Menu", function()
        ScreenGui:Destroy()
    end)
end

return Settings
